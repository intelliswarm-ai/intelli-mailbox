# Internal-only design notes / change logs that should not ship in the
# public repo. Anything under docs/internal/ stays on the maintainer's
# machine.
docs/internal/

# Claude Code: personal-machine permissions overlay. The shared
# .claude/settings.json (if any) IS committed; *.local.json is per-user.
.claude/*.local.json
.claude/.session/

# Frontend (Angular). Source under frontend/src is committed; everything
# else is built or downloaded by frontend-maven-plugin during `mvn package`.
frontend/node/
frontend/node_modules/
frontend/dist/
frontend/.angular/
frontend/out-tsc/
